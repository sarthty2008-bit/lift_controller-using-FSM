module elevator_controller (
    input clk, rst,
    input [2:0] req, // req[0]=Floor0, req[1]=Floor1, req[2]=Floor2
    output reg [1:0] floor, // current floor
    output reg door_open,
    output reg moving_up,
    output reg moving_down
);

// States
parameter IDLE = 3'd0;
parameter MOVE_UP = 3'd1;
parameter MOVE_DOWN = 3'd2;
parameter DOOR_OPEN = 3'd3;
parameter DOOR_WAIT = 3'd4;
parameter DOOR_CLOSE = 3'd5;

reg [2:0] state, next_state;
reg [2:0] pending; // pending requests register
reg [1:0] target;
reg [3:0] door_timer;

// Latch requests
always @(posedge clk or posedge rst) begin
    if (rst) pending <= 3'b000;
    else begin
        pending <= pending | req;
        // clear served floor
        if (state == DOOR_OPEN)
            pending[floor] <= 1'b0;
    end
end

// Target selection: scan algorithm (LOOK)
always @(*) begin
    if (moving_up || (!moving_down && (pending >> floor) > 0)) begin
        // prefer higher floor
        if (floor < 2 && pending[2]) target = 2;
        else if (floor < 1 && pending[1]) target = 1;
        else if (pending[0]) target = 0;
        else if (pending[1]) target = 1;
        else target = 2;
    end else begin
        // prefer lower floor
        if (floor > 0 && pending[0]) target = 0;
        else if (floor > 1 && pending[1]) target = 1;
        else if (pending[2]) target = 2;
        else if (pending[1]) target = 1;
        else target = 0;
    end
end

// State register
always @(posedge clk or posedge rst) begin
    if (rst) state <= IDLE;
    else state <= next_state;
end

// Floor movement
always @(posedge clk or posedge rst) begin
    if (rst) floor <= 2'd0;
    else if (state == MOVE_UP) floor <= floor + 1;
    else if (state == MOVE_DOWN) floor <= floor - 1;
end

// Door timer
always @(posedge clk or posedge rst) begin
    if (rst) door_timer <= 0;
    else if (state == DOOR_OPEN) door_timer <= 4'd8;
    else if (state == DOOR_WAIT && door_timer > 0) door_timer <= door_timer - 1;
end

// Next state logic
always @(*) begin
    next_state = state;
    case (state)
        IDLE: begin
            if (pending != 0) begin
                if (target > floor) next_state = MOVE_UP;
                else if (target < floor) next_state = MOVE_DOWN;
                else next_state = DOOR_OPEN;
            end
        end
        MOVE_UP: next_state = (floor == target) ? DOOR_OPEN : MOVE_UP;
        MOVE_DOWN: next_state = (floor == target) ? DOOR_OPEN : MOVE_DOWN;
        DOOR_OPEN: next_state = DOOR_WAIT;
        DOOR_WAIT: next_state = (door_timer == 0) ? DOOR_CLOSE : DOOR_WAIT;
        DOOR_CLOSE: begin
            if (pending == 0) next_state = IDLE;
            else if (target > floor) next_state = MOVE_UP;
            else if (target < floor) next_state = MOVE_DOWN;
            else next_state = DOOR_OPEN;
        end
    endcase
end

// Output logic
always @(*) begin
    door_open = (state == DOOR_OPEN || state == DOOR_WAIT);
    moving_up = (state == MOVE_UP);
    moving_down = (state == MOVE_DOWN);
end
endmodule

